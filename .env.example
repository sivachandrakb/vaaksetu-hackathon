# VaakSetu Environment Configuration
# Copy this to .env and fill in your values

# ── OpenAI (for LLM interpretation + Whisper API) ───────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Model for semantic interpretation
# Options: gpt-4o-mini (fast + cheap), gpt-4o (best quality)
OPENAI_MODEL=gpt-4o-mini

# ── Whisper ASR ───────────────────────────────────────────────────────────────
# Options: tiny, base, small, medium, large-v3
# If OPENAI_API_KEY is set, uses Whisper API (no local model download needed)
# Without API key, downloads local model (large-v3 = ~3GB)
WHISPER_MODEL=base

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (prototype): sqlite+aiosqlite:///./vaaksetu.db
# PostgreSQL (production): postgresql+asyncpg://user:pass@host/db
DATABASE_URL=sqlite+aiosqlite:///./vaaksetu.db

# ── TTS Engine ────────────────────────────────────────────────────────────────
# gtts: Google TTS (free, requires internet, supports kn/hi/en)
# coqui: Coqui TTS (local, supports Kannada via IndicTTS model)
TTS_ENGINE=gtts
